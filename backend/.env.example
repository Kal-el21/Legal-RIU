APP_PORT=8080
APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name
DB_SSLMODE=disable

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_HOURS=24
JWT_REFRESH_EXPIRES_HOURS=168

# Security
CORS_ALLOWED_ORIGINS=http://localhost:89,http://localhost:5173,http://127.0.0.1:89,http://127.0.0.1:5173
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MINUTES=15

# Default admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=12345678
ADMIN_FULL_NAME=Super Admin
ADMIN_POSITION=Administrator
ADMIN_DIVISION=Legal

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=legal-riu
MINIO_USE_SSL=false
MINIO_PRESIGN_EXPIRES_MINUTES=15
