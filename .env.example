# Docker Compose
POSTGRES_HOST_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=legal_riu_db

BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=89
NGINX_HOST_PORT=80

# Backend app
APP_PORT=8080
APP_ENV=development

# Database connection from containers
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=legal_riu_db
DB_SSLMODE=disable

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_HOURS=24
JWT_REFRESH_EXPIRES_HOURS=168

# Security
CORS_ALLOWED_ORIGINS=http://localhost:89,http://localhost:5173,http://127.0.0.1:89,http://127.0.0.1:5173
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MINUTES=15

# MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=legal-riu
MINIO_USE_SSL=false
MINIO_PRESIGN_EXPIRES_MINUTES=15

# Default admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=12345678
ADMIN_FULL_NAME=Super Admin
ADMIN_POSITION=Administrator
ADMIN_DIVISION=Legal
